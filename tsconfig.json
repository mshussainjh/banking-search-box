{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "outDir": "./dist",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "useDefineForClassFields": false,
    "rootDir": "./src"
  },
  "include": [
    "src"
  ]
}
